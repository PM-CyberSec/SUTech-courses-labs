APP_NAME=Laravel
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
AUDIT_LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=DigitalForensics
DB_USERNAME=dlds_app
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Data leakage detection engine posts JSON events here (see detection-engine/correlator.py).
# Example: export DLDS_API_URL=http://127.0.0.1:8000/api/dlds/events
DLDS_API_URL=http://127.0.0.1:8000/api/dlds/events
LARAVEL_API_URL=http://127.0.0.1:8000/api/dlds/events
SURICATA_EVE_PATH=/var/log/suricata/eve.json
DLDS_SURICATA_FROM_END=0
# ZEEK_LOG_DIR=/opt/zeek/logs/current
# ZEEK_CONN_LOG=/opt/zeek/logs/current/conn.log
DLDS_ZEEK_FROM_END=0

# Shared API key for ingestion endpoints (/api/dlds/events + /api/dlds/alerts).
# Set the same value in the Python engine request header: X-API-KEY
DLDS_API_KEY=
DLDS_HMAC_SECRET=
DLDS_INGEST_MAX_SKEW_SECONDS=300
PUBLIC_REGISTRATION=false

# LLM foundation. Use local_stub for deterministic local/tests; switch to openai
# for OpenAI-compatible chat completions.
LLM_DRIVER=local_stub
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_TIMEOUT_SECONDS=30
OPENAI_RETRY_ATTEMPTS=2
OPENAI_RETRY_DELAY_MS=250

# Local RAG foundation. Keep retrieval in memory until a vector store is added.
RAG_CHUNK_SIZE_WORDS=180
RAG_CHUNK_OVERLAP_WORDS=30

# Reverb (optional, for live alert broadcasting)
REVERB_APP_ID=digital-forensics
REVERB_APP_KEY=digital-forensics-key
REVERB_APP_SECRET=digital-forensics-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=127.0.0.1
REVERB_SERVER_PORT=8080
REVERB_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# ELK Stack Configuration
LOGSTASH_HOST=127.0.0.1
LOGSTASH_PORT=5000
ELASTICSEARCH_URL=http://localhost:9200
KIBANA_URL=http://localhost:5601

# Optional Kafka producer from the Python pipeline when PIPELINE_KAFKA_ENABLED=true.
# Host bootstrap: 127.0.0.1:19092. Docker network bootstrap: kafka-1:29092.
PIPELINE_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:19092
