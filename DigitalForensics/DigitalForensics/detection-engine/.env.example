# API target (prefer DLDS_API_URL; legacy fallback: LARAVEL_API_URL)
DLDS_API_URL=http://127.0.0.1:8000/api/dlds/events
LARAVEL_API_URL=http://127.0.0.1:8000/api/dlds/events

# If Laravel ingestion is protected with X-API-KEY middleware
DLDS_API_KEY=
DLDS_HMAC_SECRET=

# Emission controls: alerts | all
DLDS_EMIT_MODE=all

# Optional local SQLite persistence path
# DLDS_SQLITE_PATH=/tmp/dlds_events.sqlite

# Poll intervals (seconds)
DLDS_ZEEK_POLL=0.2
DLDS_SURICATA_POLL=0.2
DLDS_DETECT_INTERVAL=0.5
DLDS_SS_REFRESH_SEC=1.0
DLDS_ZEEK_FROM_END=0
DLDS_SURICATA_FROM_END=0

# Net mapper command (must include process info for pid mapping)
DLDS_SS_CMD="ss -tnp state established"

# Exfiltration rule tuning
DLDS_EXFIL_BYTES=1048576
DLDS_EXFIL_REQUIRE_PUBLIC_DST=1

# HTTP retry behavior
DLDS_HTTP_RETRIES=3
DLDS_HTTP_BACKOFF=0.5
DLDS_HTTP_TIMEOUT=10
DLDS_HTTP_VERBOSE_RETRIES=0
DLDS_HTTP_FAILURE_COOLDOWN=2

# Runtime controls
DLDS_TEST_EVENT=1
DLDS_SKIP_RUN_SERVICES=1
DLDS_SERVICES_VERBOSE=0
DLDS_SERVICES_TIMEOUT=45
DLDS_RUN_SERVICES=0
DLDS_LOG_LEVEL=INFO
DLDS_AUDIT_POLL=0.2

# Log locations overrides (optional)
SURICATA_EVE_PATH=/var/log/suricata/eve.json
SURICATA_EVE=/var/log/suricata/eve.json
# ZEEK_LOG_DIR=/opt/zeek/logs/current
# ZEEK_CONN_LOG=/opt/zeek/logs/current/conn.log
# AUDIT_LOG=/var/log/audit/audit.log
