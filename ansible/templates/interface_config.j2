!
! Interface Configuration
! Generated by AutoConfigLab
!
{% for interface in interfaces %}
interface {{ interface.name }}
 description {{ interface.description | default('Configured by AutoConfigLab') }}
!
{% if interface.mode == 'access' %}
 switchport mode access
 switchport access vlan {{ interface.vlan | default(1) }}
!
{% elif interface.mode == 'trunk' %}
 switchport mode trunk
 switchport trunk encapsulation dot1q
{% if interface.allowed_vlans %}
 switchport trunk allowed vlan {{ interface.allowed_vlans }}
{% endif %}
{% if interface.native_vlan %}
 switchport trunk native vlan {{ interface.native_vlan }}
{% endif %}
!
{% elif interface.mode == 'routed' %}
 no switchport
{% if interface.ip_address %}
 ip address {{ interface.ip_address }} {{ interface.subnet_mask | default('255.255.255.0') }}
{% endif %}
!
{% endif %}
{% if interface.speed %}
 speed {{ interface.speed }}
{% endif %}
{% if interface.duplex %}
 duplex {{ interface.duplex }}
{% endif %}
 no shutdown
!
{% endfor %}