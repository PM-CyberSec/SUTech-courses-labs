!
! Routing Configuration
! Generated by AutoConfigLab
!
{% if routing_protocol == 'static' %}
{% for route in static_routes %}
ip route {{ route.destination }} {{ route.mask }} {{ route.next_hop }}
{% if route.distance %}
 {{ route.distance }}
{% endif %}
!
{% endfor %}
{% elif routing_protocol == 'ospf' %}
router ospf {{ process_id | default(1) }}
{% for network in ospf_networks %}
 network {{ network.address }} {{ network.wildcard }} area {{ network.area | default(0) }}
{% endfor %}
{% if ospf_passive_interface %}
{% for iface in ospf_passive_interface %}
 passive-interface {{ iface }}
{% endfor %}
{% endif %}
!
{% elif routing_protocol == 'eigrp' %}
router eigrp {{ asn }}
{% for network in eigrp_networks %}
 network {{ network.address }} {{ network.wildcard }}
{% endfor %}
{% if eigrp_passive_interface %}
{% for iface in eigrp_passive_interface %}
 passive-interface {{ iface }}
{% endfor %}
{% endif %}
!
{% elif routing_protocol == 'bgp' %}
router bgp {{ bgp_asn }}
{% for neighbor in bgp_neighbors %}
 neighbor {{ neighbor.ip }} remote-as {{ neighbor.remote_as }}
{% if neighbor.update_source %}
 update-source {{ neighbor.update_source }}
{% endif %}
{% if neighbor.next_hop_self %}
 next-hop-self
{% endif %}
{% endfor %}
{% for network in bgp_networks %}
 network {{ network.mask }} mask {{ network.mask }}
{% endfor %}
!
{% endif %}
!